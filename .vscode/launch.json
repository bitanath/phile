  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug with features",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["run", "--bin=phile", "--features", "metal,embed"]
      },
      "args": ["hi"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "debug"
      }
    }
  ]
}
